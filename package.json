{
  "name": "oscaudiolink",
  "version": "1.0.0",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "copyright": "Copyright © 2024-2025 NekoSuneVR",
    "appId": "com.nekosunevr.oscaudiolink",
    "productName": "OSCAudioLink",
    "appx": {
      "backgroundColor": "#ffffff",
      "displayName": "OSCAudioLink",
      "publisher": "CN=NekoSuneVR",
      "publisherDisplayName": "NekoSuneVR",
      "identityName": "com.nekosunevr.oscaudiolink"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": ["**/*", "!node_modules/.cache"],
    "win": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": ["nsis", "msi"],
      "icon": "assets/icon.ico",
      "files": [
        "main.js",
        "preload.js",
        "renderer.js",
        "index.html",
        "settings.js",
        "LICENSE",
        "README.md",
        "CHANGELOG.md",
        "assets/**/*",
        "modules/**/*",
        "package.json",
        "node_modules/**/*"
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE",
      "oneClick": false
    }
  },
  "keywords": [],
  "author": "NekoSuneVR",
  "license": "MIT",
  "description": "OSCAudiolink is Program use Audio to Vrchat OSC and Quest / Mobile Friendly",
  "dependencies": {
    "axios": "^1.7.7",
    "dgram": "^1.0.1",
    "electron-store": "^8.2.0",
    "express": "^4.21.1",
    "fft-js": "^0.0.12",
    "mathjs": "^14.7.0",
    "node-fetch": "^3.3.2",
    "node-window-manager": "^2.2.4",
    "osc-min": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^25.1.8"
  }
}
